{
  "rewrites": [
    {
      "source": "/share/:id",
      "destination": "/api/index"
    },
    {
      "source": "/(.*(?:\\.png|\\.jpg|\\.jpeg|\\.gif|\\.svg|\\.gltf|\\.js|\\.css|\\.json|\\.ico|\\.woff|\\.woff2).*$)",
      "destination": "/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
